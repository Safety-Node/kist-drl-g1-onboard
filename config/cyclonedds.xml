<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">

  <!--
    Domain 0: NX-internal ROS 2 nodes (loopback only).
    imu_node is the only node that needs eth0 + robot peer for G1 SDK access;
    it overrides CYCLONEDDS_URI in-process (see imu_node.py main()) so only its
    own DDS domain picks up the robot peer. All other domain 0 nodes stay on lo
    to avoid the EAGAIN discovery-probe storm that unicast robot peers cause.
    Raw Unitree DDS topics potentially leaking via imu_node are tracked in TASK-32.
  -->
  <Domain Id="0">
    <General>
      <Interfaces>
        <NetworkInterface name="lo" multicast="false"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
    </General>
    <Discovery>
      <Peers>
        <Peer address="localhost"/>
      </Peers>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>20</MaxAutoParticipantIndex>
    </Discovery>
    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>

  <!--
    Domain 1: Bridge domain shared with the workstation PC.
    outbound_relay and inbound_relay publish/subscribe here to exchange
    /bridge/* topics with the PC. eth0 + loopback so relay nodes on the
    same host can also discover each other.
    DDS_PEER_IP must be set to the workstation IP before launch.
  -->
  <Domain Id="1">
    <General>
      <Interfaces>
        <NetworkInterface name="eth0" priority="default" multicast="false"/>
        <NetworkInterface name="lo"   priority="default" multicast="false"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>
    <Discovery>
      <Peers>
        <Peer address="localhost"/>
        <Peer address="${DDS_PEER_IP}"/>
      </Peers>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>20</MaxAutoParticipantIndex>
    </Discovery>
    <Internal>
      <Watermarks>
        <WhcHigh>2MB</WhcHigh>
      </Watermarks>
    </Internal>
    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>

</CycloneDDS>
