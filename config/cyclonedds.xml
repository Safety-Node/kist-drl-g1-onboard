<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">

  <!--
    Domain 0: NX-internal + G1 SDK.
    eth0 is included so the G1 SDK participant (unitree_sdk2py / monkey-patched
    DomainParticipant) can reach the robot via multicast on the 192.168.123.x LAN.
    lo is preferred (priority 2) for intra-NX ROS 2 data traffic.
    eth0 multicast is used for SDK <-> robot DDS discovery (no unicast peer needed;
    adding the robot IP as a unicast peer causes an EAGAIN probe storm because the
    robot does not respond to standard CycloneDDS SPDP on ports 7410-7448).
    Raw Unitree DDS topics leaking into `ros2 topic list` are tracked in TASK-32.
  -->
  <Domain Id="0">
    <General>
      <Interfaces>
        <NetworkInterface name="lo"   priority="2" multicast="false"/>
        <NetworkInterface name="eth0" priority="1" multicast="true"/>
      </Interfaces>
      <AllowMulticast>true</AllowMulticast>
    </General>
    <Discovery>
      <Peers>
        <Peer address="localhost"/>
      </Peers>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>20</MaxAutoParticipantIndex>
    </Discovery>
    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>

  <!--
    Domain 1: Bridge domain shared with the workstation PC.
    outbound_relay and inbound_relay publish/subscribe here to exchange
    /bridge/* topics with the PC. eth0 + loopback so relay nodes on the
    same host can also discover each other.
    DDS_PEER_IP must be set to the workstation IP before launch.
  -->
  <Domain Id="1">
    <General>
      <Interfaces>
        <NetworkInterface name="eth0" priority="default" multicast="false"/>
        <NetworkInterface name="lo"   priority="default" multicast="false"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>
    <Discovery>
      <Peers>
        <Peer address="localhost"/>
        <Peer address="${DDS_PEER_IP}"/>
      </Peers>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>20</MaxAutoParticipantIndex>
    </Discovery>
    <Internal>
      <Watermarks>
        <WhcHigh>2MB</WhcHigh>
      </Watermarks>
    </Internal>
    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>

</CycloneDDS>
